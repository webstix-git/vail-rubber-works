# Cloudflare Turnstile (public site key — safe for the browser)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADmfswnvqnaPvBUI

# Cloudflare Turnstile secret (server only — required for spam protection)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Optional: comma-separated hostnames allowed in Turnstile verification responses
# TURNSTILE_ALLOWED_HOSTNAMES=preview.example.com,staging.example.com
